---
import { getCollection, render } from "astro:content";
import EntryLayout from "@/layouts/EntryLayout.astro";
import { collectionPaths, formatDate, makeTitleMap } from "@/lib/content";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((entry) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const [papers, skills, mcpTools] = await Promise.all([
  getCollection("papers"),
  getCollection("skills"),
  getCollection("mcp")
]);
const paperLabels = makeTitleMap(papers);
const skillLabels = makeTitleMap(skills);
const mcpLabels = makeTitleMap(mcpTools);
const { Content } = await render(entry);
---

<EntryLayout
  pageTitle={entry.data.title}
  kind="Article"
  summary={entry.data.summary}
  backHref="/articles/"
  backLabel="All articles"
  tags={entry.data.tags}
  links={entry.data.links}
  meta={[
    { label: "Date", value: formatDate(entry.data.date) },
    { label: "Status", value: entry.data.status },
    { label: "Trail", value: entry.data.trail }
  ]}
  relations={[
    {
      title: "Related Papers",
      items: entry.data.relatedPapers,
      labels: paperLabels,
      basePath: collectionPaths.papers
    },
    {
      title: "Related Skills",
      items: entry.data.relatedSkills,
      labels: skillLabels,
      basePath: collectionPaths.skills
    },
    {
      title: "MCP Tools",
      items: entry.data.relatedMcp,
      labels: mcpLabels,
      basePath: collectionPaths.mcp
    }
  ]}
>
  <Content />
</EntryLayout>
